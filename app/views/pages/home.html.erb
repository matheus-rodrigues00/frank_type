<% content_for :title, t("pages.practice.title") %>
<% content_for :body_controller, "typing" %>
<% content_for :body_action, "keydown@window->typing#globalKeydown" %>
<% content_for :typing_excerpts_value, Typing::ExcerptCatalog.as_json(locale: I18n.locale).to_json.html_safe %>
<% content_for :typing_i18n_value, t("js.typing").to_json.html_safe %>
<% content_for :header_controls do %>
  <div class="flex flex-wrap items-center justify-center gap-2">
    <div class="flex flex-wrap justify-center gap-2" aria-label="<%= t("pages.practice.category_label") %>">
      <% %w[random scifi fantasy biography].each do |category| %>
        <button type="button" class="choice-pill" data-action="typing#setCategory" data-typing-category-param="<%= category %>" data-typing-target="categoryButton"><%= t("pages.practice.categories.#{category}") %></button>
      <% end %>
    </div>
    <span class="ui-divider mx-1 hidden h-5 w-px sm:inline-block" aria-hidden="true"></span>
    <div class="flex flex-wrap justify-center gap-2" aria-label="<%= t("pages.practice.timer_label") %>">
      <% [15, 30, 60].each do |seconds| %>
        <button type="button" class="choice-pill" data-action="typing#setDuration" data-typing-duration-param="<%= seconds %>" data-typing-target="durationButton"><%= seconds %>s</button>
      <% end %>
    </div>
  </div>
<% end %>

<section class="mx-auto max-w-6xl">
  <div class="glass-panel p-4 sm:p-6 lg:p-8">
    <div class="border-subtle text-subtle mb-5 grid grid-cols-2 gap-x-8 gap-y-2 border-b pb-3 text-xs sm:flex sm:items-center sm:gap-x-10 sm:text-sm">
      <div class="inline-flex items-baseline whitespace-nowrap">
        <span class="mr-2 uppercase tracking-[0.18em]"><%= t("pages.practice.metrics.wpm") %></span>
        <span class="text-primary font-mono text-base font-semibold sm:text-lg" data-typing-target="wpm">0</span>
      </div>
      <div class="inline-flex items-baseline whitespace-nowrap">
        <span class="mr-2 uppercase tracking-[0.18em]"><%= t("pages.practice.metrics.accuracy") %></span>
        <span class="text-primary font-mono text-base font-semibold sm:text-lg"><span data-typing-target="accuracy">100</span><span class="text-subtle">%</span></span>
      </div>
      <div class="inline-flex items-baseline whitespace-nowrap">
        <span class="mr-2 uppercase tracking-[0.18em]"><%= t("pages.practice.metrics.time") %></span>
        <span class="text-primary font-mono text-base font-semibold sm:text-lg"><span data-typing-target="timeLeft">30</span><span class="text-subtle">s</span></span>
      </div>
      <div class="inline-flex items-baseline whitespace-nowrap">
        <span class="mr-2 uppercase tracking-[0.18em]"><%= t("pages.practice.metrics.chars") %></span>
        <span class="text-primary font-mono text-base font-semibold sm:text-lg" data-typing-target="progress">0/0</span>
      </div>
      <div class="text-subtle ml-auto hidden text-right text-xs sm:block" data-typing-target="stateLabel"><%= t("pages.practice.state_ready") %></div>
    </div>

    <div
      class="typing-surface"
      data-typing-target="typingSurface"
      data-action="click->typing#focus keydown->typing#keydown focusin->typing#surfaceFocused focusout->typing#surfaceBlurred"
    >
      <textarea
        class="typing-input-sink"
        data-typing-target="inputSink"
        data-action="beforeinput->typing#beforeInput input->typing#inputChanged paste->typing#blockBulkInput drop->typing#blockBulkInput"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        aria-label="<%= t("pages.practice.typing_area_label") %>"
      ></textarea>
      <span class="typing-paused-overlay hidden" data-typing-target="pausedOverlay" aria-hidden="true">
        <span class="typing-paused-hint"><%= t("pages.practice.paused_hint") %></span>
      </span>
      <span class="text-subtle mb-8 flex flex-wrap items-center justify-between gap-3 text-xs sm:text-sm">
        <span data-typing-target="source"></span>
        <span class="help-chip"><%= t("pages.practice.help_hint") %></span>
      </span>
      <span class="scrollbar-hidden block max-h-[31vh] overflow-y-auto scroll-smooth pr-2" data-typing-target="textScroller">
        <span class="typing-text" data-typing-target="text"></span>
      </span>
      <span class="slow-pair-panel hidden" data-typing-target="slowPairPanel">
        <span class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <span>
            <span class="block text-xs font-bold uppercase tracking-[0.24em]" style="color: var(--color-warning);"><%= t("pages.practice.slow_combinations") %></span>
            <span class="text-muted mt-1 block text-xs"><%= t("pages.practice.slow_combinations_help") %></span>
          </span>
          <span class="flex flex-wrap gap-2" data-typing-target="slowPairList"></span>
        </span>
      </span>
    </div>

    <div class="race-panel" aria-label="<%= t("pages.practice.race_label") %>">
      <% [["slow", "🐢", "slowRacer"], ["you", "⌨️", "userRacer"], ["fast", "🚀", "fastRacer"]].each do |label, glyph, target| %>
        <div class="border-subtle relative h-9 border-t first:border-t-0">
          <span class="racer-label absolute left-0 top-2 w-12 text-[10px] font-bold uppercase tracking-[0.22em]"><%= t("pages.practice.racers.#{label}") %></span>
          <span class="absolute right-0 top-2 opacity-50">🏁</span>
          <span class="lane-line absolute left-14 right-7 top-4 h-px"></span>
          <span data-typing-target="<%= target %>" class="absolute top-1 text-xl transition-all duration-300 ease-out <%= label == "you" ? "user-racer" : "opacity-80" %>" style="left: 3.5rem;"><%= glyph %></span>
        </div>
      <% end %>
    </div>

    <div class="result-panel hidden" data-typing-target="results">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <div class="flex items-end gap-3">
            <span class="text-primary font-mono text-6xl font-black leading-none sm:text-7xl" data-typing-target="resultWpm">0</span>
            <span class="text-accent pb-2 text-sm font-bold uppercase tracking-[0.3em]"><%= t("pages.practice.result_wpm") %></span>
          </div>
          <p class="text-body mt-2 text-sm" data-typing-target="resultDetails"></p>
        </div>
        <%= link_to t("pages.practice.see_profile"), profile_path, class: "accent-button" %>
      </div>
    </div>
  </div>

  <div
    class="overlay-backdrop fixed inset-0 z-50 hidden items-center justify-center p-4 backdrop-blur-sm"
    data-typing-target="helpOverlay"
    data-action="click->typing#closeHelpFromBackdrop"
    role="dialog"
    aria-modal="true"
    aria-labelledby="typing-help-title"
  >
    <div class="modal-panel">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-accent text-xs font-medium uppercase tracking-[0.35em]"><%= t("pages.practice.help.eyebrow") %></p>
          <h2 id="typing-help-title" class="text-primary mt-2 text-2xl font-black"><%= t("pages.practice.help.title") %></h2>
        </div>
        <button type="button" class="choice-pill" data-action="typing#closeHelp">Esc</button>
      </div>

      <dl class="text-body mt-6 space-y-3 text-sm">
        <div class="surface-soft flex items-center justify-between gap-4 rounded-2xl px-4 py-3">
          <dt><%= t("pages.practice.help.open") %></dt>
          <dd class="key-chip">?</dd>
        </div>
        <div class="surface-soft flex items-center justify-between gap-4 rounded-2xl px-4 py-3">
          <dt><%= t("pages.practice.help.close") %></dt>
          <dd class="key-chip">Esc</dd>
        </div>
        <div class="surface-soft flex items-center justify-between gap-4 rounded-2xl px-4 py-3">
          <dt><%= t("pages.practice.help.restart") %></dt>
          <dd class="key-chip">Esc</dd>
        </div>
        <div class="surface-soft flex items-center justify-between gap-4 rounded-2xl px-4 py-3">
          <dt><%= t("pages.practice.help.random") %></dt>
          <dd class="key-chip">Tab</dd>
        </div>
      </dl>
    </div>
  </div>
</section>
