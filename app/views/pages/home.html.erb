<% content_for :title, "Practice · Frank Type" %>

<section
  class="mx-auto max-w-6xl"
  data-controller="typing"
  data-typing-excerpts-value="<%= json_escape(Typing::ExcerptCatalog.as_json.to_json) %>"
>
  <div class="glass-panel p-4 sm:p-6 lg:p-8">
    <div class="mb-5 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.35em] text-teal-200">Typing room</p>
        <h1 class="mt-2 text-2xl font-black tracking-tight text-white sm:text-3xl">Public-domain prose practice</h1>
      </div>

      <div class="flex shrink-0 flex-wrap gap-2" aria-label="Timer length">
        <% [15, 30, 60].each do |seconds| %>
          <button type="button" class="rounded-full border border-white/10 px-3 py-1.5 text-xs font-semibold text-slate-400 transition hover:border-teal-300/60 hover:text-white sm:text-sm" data-action="typing#setDuration" data-typing-duration-param="<%= seconds %>" data-typing-target="durationButton"><%= seconds %>s</button>
        <% end %>
      </div>
    </div>

    <div class="mb-5 grid grid-cols-2 gap-x-8 gap-y-2 border-y border-white/10 py-3 text-xs text-slate-500 sm:flex sm:items-center sm:gap-x-10 sm:text-sm">
      <div class="inline-flex items-baseline whitespace-nowrap">
        <span class="mr-2 uppercase tracking-[0.18em]">wpm</span>
        <span class="font-mono text-base font-semibold text-slate-200 sm:text-lg" data-typing-target="wpm">0</span>
      </div>
      <div class="inline-flex items-baseline whitespace-nowrap">
        <span class="mr-2 uppercase tracking-[0.18em]">accuracy</span>
        <span class="font-mono text-base font-semibold text-slate-200 sm:text-lg"><span data-typing-target="accuracy">100</span><span class="text-slate-500">%</span></span>
      </div>
      <div class="inline-flex items-baseline whitespace-nowrap">
        <span class="mr-2 uppercase tracking-[0.18em]">time</span>
        <span class="font-mono text-base font-semibold text-slate-200 sm:text-lg"><span data-typing-target="timeLeft">30</span><span class="text-slate-500">s</span></span>
      </div>
      <div class="inline-flex items-baseline whitespace-nowrap">
        <span class="mr-2 uppercase tracking-[0.18em]">chars</span>
        <span class="font-mono text-base font-semibold text-slate-200 sm:text-lg" data-typing-target="progress">0/0</span>
      </div>
      <div class="ml-auto hidden text-right text-xs text-slate-500 sm:block" data-typing-target="stateLabel">click here and start typing</div>
    </div>

    <button
      type="button"
      class="block min-h-[48vh] w-full rounded-[1.75rem] border border-white/10 bg-slate-950/50 p-5 text-left outline-none ring-teal-300/40 transition focus:border-teal-300/40 focus:ring-4 sm:p-8"
      data-typing-target="typingSurface"
      data-action="click->typing#focus keydown->typing#keydown"
      tabindex="0"
      aria-label="Typing practice area"
    >
      <span class="mb-8 flex flex-wrap items-center justify-between gap-3 text-xs text-slate-500 sm:text-sm">
        <span data-typing-target="source"></span>
        <span class="rounded-full border border-white/10 px-3 py-1 text-slate-500">Tab + Enter restart · Ctrl + N new text</span>
      </span>
      <span class="flex flex-wrap items-baseline gap-x-[0.55ch] gap-y-4 overflow-hidden font-mono text-2xl leading-[1.75] tracking-normal text-slate-500 sm:text-3xl" data-typing-target="text"></span>
    </button>

    <div class="mt-6 hidden rounded-3xl border border-teal-300/20 bg-teal-300/10 p-5" data-typing-target="results">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-teal-100">Session saved locally</p>
          <p class="mt-2 text-slate-300" data-typing-target="resultSummary"></p>
        </div>
        <%= link_to "See profile", profile_path, class: "rounded-full bg-teal-300 px-5 py-3 text-center text-sm font-black text-slate-950 transition hover:bg-teal-200" %>
      </div>
    </div>
  </div>
</section>
